# Datenverzeichnis im Container (gemapptes Volume)
EPUB_DATA_DIR=/app/data

# Erlaubte CORS-Origins (Dev-Frontend)
EPUB_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Maximale Uploadgröße in Bytes (Default 50 MB)
EPUB_MAX_UPLOAD_BYTES=52428800

# --- KI (Google Gemini) ---
# Leer lassen => KI-Funktionen sind deaktiviert (App läuft trotzdem).
EPUB_GEMINI_API_KEY=
# Optional: Standardmodelle überschreiben (in der Oberfläche pro Generierung wählbar)
EPUB_GEMINI_TEXT_MODEL=gemini-3.5-flash
EPUB_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
EPUB_GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
EPUB_GEMINI_TTS_VOICE=Kore
